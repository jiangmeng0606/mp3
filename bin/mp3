#!/usr/bin/env bash
set -e

# 获取脚本真实路径，支持软链
# 优先使用 MP3_HOME 环境变量，否则自动推断
if [ -z "$MP3_HOME" ]; then
  SCRIPT_PATH="$(readlink -f "$0")"
  MP3_HOME="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
fi

# 检查目录是否存在
if [ ! -d "$MP3_HOME" ]; then
  echo "Error: MP3_HOME directory '$MP3_HOME' does not exist."
  exit 1
fi

JAR_FILE="$MP3_HOME/mp3-1.0-SNAPSHOT.jar"
if [ ! -f "$JAR_FILE" ]; then
  echo "Error: $JAR_FILE not found in $MP3_HOME"
  exit 1
fi

JAVA_CMD="${JAVA_HOME:+$JAVA_HOME/bin/}java"
if ! command -v "$JAVA_CMD" &>/dev/null; then
  JAVA_CMD="java"
fi

if ! command -v "$JAVA_CMD" &>/dev/null; then
  echo "Error: Java not found. Please install Java or set JAVA_HOME."
  exit 1
fi

# 不改变当前目录，直接执行
"$JAVA_CMD" -cp "$JAR_FILE" com.haizhi.mp3.Main "$@"

